#!/bin/sh
# shellcheck shell=sh

set -eu

. /usr/local/bin/backend-functions

SCRIPT_NAME="ENTRYPOINT"

# Display project information
echo "===================================================================================="
echo "🚀 NordVPN WireGuard Docker Container"
echo "===================================================================================="
echo "📋 Description: Docker container for NordVPN with WireGuard and advanced networking"
echo "👤 Author: Alexander Zinchenko <alexander@zinchenko.com>"
echo "🔗 Repository: https://github.com/azinchen/nordvpn-wg"
echo "📚 Documentation: https://github.com/azinchen/nordvpn-wg/wiki"
echo "🏷️ Image Version: __IMAGE_VERSION__"
echo "📅 Build Date: __BUILD_DATE__"
echo "===================================================================================="

log "$SCRIPT_NAME" "Applying security rules"

# ---- helpers ---------------------------------------------------------------

try_backend()
{
    _bin="$1"
    _probe="${2:-full}"
    # Prove backend can change policy on this kernel (DROP then revert)
    $_bin -t filter -S >/dev/null 2>&1 || return 1
    $_bin -t filter -P OUTPUT DROP >/dev/null 2>&1 || return 1
    $_bin -t filter -P OUTPUT ACCEPT >/dev/null 2>&1 || true
    if [ "$_probe" = "full" ]; then
        # wg-quick pipes its anti-leak rules into `iptables-restore -n`, which
        # exercises kernel paths the policy probe does not (nft generation id
        # fetch). Partially-working nft kernels, e.g. Synology DSM, pass the
        # policy probe yet fail restore, so require it too (issue #207).
        printf '*filter\nCOMMIT\n' | "${_bin}-restore" -n >/dev/null 2>&1 || return 1
    fi
    return 0
}

flush_nft_if_dirty_v4()
{
    # Flush nftables v4 only if we selected legacy for v4 AND nft tables actually carry rules
    if [ "${_IPT}" = "iptables-legacy" ] && command -v iptables-nft >/dev/null 2>&1; then
        if iptables-nft -S 2>/dev/null | grep -q '^-A ' || iptables-nft -t nat -S 2>/dev/null | grep -q '^-A '; then
            iptables-nft -F 2>/dev/null || true
            iptables-nft -t nat -F 2>/dev/null || true
            iptables-nft -X 2>/dev/null || true
            log "$SCRIPT_NAME" "Flushed IPv4 nftables to avoid mixed stacks"
        fi
    fi
}

flush_nft_if_dirty_v6()
{
    # Flush nftables v6 only if we selected legacy for v6 AND nft v6 tables actually carry rules
    if [ -n "${_IP6T:-}" ] && [ "${_IP6T}" = "ip6tables-legacy" ] && command -v ip6tables-nft >/dev/null 2>&1; then
        if ip6tables-nft -S 2>/dev/null | grep -q '^-A ' || ip6tables-nft -t nat -S 2>/dev/null | grep -q '^-A '; then
            ip6tables-nft -F 2>/dev/null || true
            ip6tables-nft -t nat -F 2>/dev/null || true
            ip6tables-nft -X 2>/dev/null || true
            log "$SCRIPT_NAME" "Flushed IPv6 nftables to avoid mixed stacks"
        fi
    fi
}

# ---- IPv4 backend picker: prefer nft, fall back to legacy ------------------

pick_ipv4_backend()
{
    _IPT=""
    if command -v iptables >/dev/null 2>&1 && iptables -V 2>&1 | grep -qi "(nf_tables)"; then
        try_backend iptables && _IPT="iptables"
    fi
    [ -n "$_IPT" ] || { command -v iptables-legacy >/dev/null 2>&1 && try_backend iptables-legacy && _IPT="iptables-legacy"; }
    [ -n "$_IPT" ] || { command -v iptables >/dev/null 2>&1 && try_backend iptables && _IPT="iptables"; }
    # Policy-only fallback: if no backend passes the restore probe, keep the
    # pre-restore-check selection behavior rather than refusing to start.
    [ -n "$_IPT" ] || { command -v iptables-legacy >/dev/null 2>&1 && try_backend iptables-legacy policy && _IPT="iptables-legacy"; }
    [ -n "$_IPT" ] || { command -v iptables >/dev/null 2>&1 && try_backend iptables policy && _IPT="iptables"; }
    [ -n "$_IPT" ] || { log_error "$SCRIPT_NAME" "ERROR: no working iptables (IPv4) found"; exit 1; }

    log "$SCRIPT_NAME" "Kernel: $(uname -r)"
    log "$SCRIPT_NAME" "Using iptables backend: ${_IPT}"
}

# ---- IPv6 backend picker: prefer nft, fall back to legacy ------------------

pick_ipv6_backend()
{
    _IP6T=""
    if command -v ip6tables >/dev/null 2>&1 && ip6tables -V 2>&1 | grep -qi "(nf_tables)"; then
        try_backend ip6tables && _IP6T="ip6tables"
    fi
    [ -n "$_IP6T" ] || { command -v ip6tables-legacy >/dev/null 2>&1 && try_backend ip6tables-legacy && _IP6T="ip6tables-legacy"; } || true
    [ -n "$_IP6T" ] || { command -v ip6tables >/dev/null 2>&1 && try_backend ip6tables && _IP6T="ip6tables"; } || true
    [ -n "$_IP6T" ] || { command -v ip6tables-legacy >/dev/null 2>&1 && try_backend ip6tables-legacy policy && _IP6T="ip6tables-legacy"; } || true
    [ -n "$_IP6T" ] || { command -v ip6tables >/dev/null 2>&1 && try_backend ip6tables policy && _IP6T="ip6tables"; } || true

    # Last-resort: if a binary exists at all, use it (even if probe failed)
    [ -n "$_IP6T" ] || { command -v ip6tables-legacy >/dev/null 2>&1 && _IP6T="ip6tables-legacy"; } || true
    [ -n "$_IP6T" ] || { command -v ip6tables >/dev/null 2>&1 && _IP6T="ip6tables"; } || true

    if [ -n "$_IP6T" ]; then
        log "$SCRIPT_NAME" "Using ip6tables backend: ${_IP6T}"
    else
        log "$SCRIPT_NAME" "IPv6 support unavailable"
    fi
}

verify_ipv6_backend()
{
    # If we picked something for v6, make sure v6 tables actually exist and nat table is usable.
    if [ -n "$_IP6T" ]; then
        if ! ${_IP6T} -t filter -S >/dev/null 2>&1 || ! ${_IP6T} -t nat -F >/dev/null 2>&1; then
            log "$SCRIPT_NAME" "IPv6 tables unavailable in current namespace"
            _IP6T=""
        fi
    fi
}

# ---- bind the plain iptables names to the selected backend -----------------

multi_for()
{
    case "$1" in
        *-legacy) echo "/usr/sbin/xtables-legacy-multi" ;;
        *)        echo "/usr/sbin/xtables-nft-multi" ;;
    esac
}

install_tolerant_restore()
{
    _name="$1"
    _tmulti="$2"
    # Remove the symlink first: writing through it would clobber the multi
    # binary it points at.
    rm -f "/usr/sbin/${_name}"
    {
        printf '#!/bin/sh\n'
        printf '# Generated by nordvpn-wg entrypoint (ALLOW_MISSING_IPTABLES_RULES=true):\n'
        printf '# tolerate restore failures on kernels missing netfilter modules.\n'
        printf 'if ! %s %s "$@"; then\n' "$_tmulti" "$_name"
        printf '    echo "WARNING: %s failed; continuing without these rules (ALLOW_MISSING_IPTABLES_RULES=true)" >&2\n' "$_name"
        printf 'fi\n'
        printf 'exit 0\n'
    } > "/usr/sbin/${_name}"
    chmod 0755 "/usr/sbin/${_name}"
}

bind_backend_names()
{
    # Alpine points the unprefixed names (iptables, iptables-restore, ...) at
    # the nft backend unconditionally. wg-quick calls `iptables-restore -n`
    # by name, bypassing the ${IPT} selection above; on kernels where nft is
    # unusable that call fails and wg-quick tears the tunnel down (issue
    # #207). Repoint the plain names at the selected backend so every
    # consumer agrees with the probe result.
    _v4multi="$(multi_for "$_IPT")"
    for _name in iptables iptables-restore iptables-save; do
        ln -sf "$_v4multi" "/usr/sbin/$_name"
    done
    # With no v6 backend selected, bind the v6 names to the v4 backend anyway:
    # wg-quick still calls ip6tables-restore if ALLOWED_IPS contains ::/0.
    _v6multi="$_v4multi"
    [ -z "${_IP6T:-}" ] || _v6multi="$(multi_for "$_IP6T")"
    for _name in ip6tables ip6tables-restore ip6tables-save; do
        ln -sf "$_v6multi" "/usr/sbin/$_name"
    done

    # Escape hatch for kernels that cannot load the modules behind wg-quick's
    # anti-leak rules with either backend (Synology DSM lacks iptable_raw and
    # the comment/addrtype extensions), where restore failure would otherwise
    # abort wg-quick. The container's own default-DROP firewall remains the
    # kill switch; only wg-quick's raw/mangle extras are skipped.
    if [ "$(to_bool "${ALLOW_MISSING_IPTABLES_RULES:-}")" = "true" ]; then
        install_tolerant_restore iptables-restore "$_v4multi"
        install_tolerant_restore ip6tables-restore "$_v6multi"
        log "$SCRIPT_NAME" "ALLOW_MISSING_IPTABLES_RULES enabled: restore failures will be tolerated"
    fi
}

pick_ipv4_backend
pick_ipv6_backend
verify_ipv6_backend
bind_backend_names

# If we chose legacy for a family, clear any existing nft rules for that family to avoid mixed stacks
flush_nft_if_dirty_v4
flush_nft_if_dirty_v6

# Publish for other scripts
mkdir -p /run/xt
{
    printf 'IPT=%s\n' "$_IPT"
    printf 'IP6T=%s\n' "$_IP6T"
} > /run/xt/backend.env
chmod 0644 /run/xt/backend.env

. /run/xt/backend.env

# ---- secure defaults (v4 + v6 if available) --------------------------------

# Default DROP policies (set ASAP)
run4_critical -t filter -P OUTPUT DROP
run4_critical -t filter -P INPUT  DROP
run4_critical -t filter -P FORWARD DROP
run6_critical -t filter -P OUTPUT DROP
run6_critical -t filter -P INPUT  DROP
run6_critical -t filter -P FORWARD DROP

# Flush existing rules (filter + nat), best effort
run4_critical -t filter -F; run4_critical -t filter -X
run4_critical -t nat    -F; run4_critical -t nat    -X
run6_critical -t filter -F; run6_critical -t filter -X
run6_critical -t nat    -F; run6_critical -t nat    -X

# Allow loopback (critical for local apps)
run4 -A INPUT  -i lo -j ACCEPT
run4 -A OUTPUT -o lo -j ACCEPT

log "$SCRIPT_NAME" "Security rules applied - all traffic blocked by default"

exec /init "$@"
